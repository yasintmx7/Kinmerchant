# ============================================================
# Kintara Merchant Alert Bot -- Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit your real .env file to version control.

# ----------------------------------------------------------
# REQUIRED: Telegram Bot Token from @BotFather
# ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=put_bot_token_here

# ----------------------------------------------------------
# REQUIRED: Your Telegram Chat ID
# Get it by messaging @userinfobot in Telegram
# ----------------------------------------------------------
TELEGRAM_CHAT_ID=put_chat_id_here

# ----------------------------------------------------------
# OPTIONAL: Your Kintara browser cookie (for personal alerts)
# Needed to check your personal gold claim status.
# Copy your full "Cookie" header value from your browser
# DevTools (F12 > Network tab > any kintara.com request >
# Request Headers > Cookie).
#
# Leave blank or remove this line to skip personal alerts.
# ----------------------------------------------------------
KINTARA_COOKIE=

# ----------------------------------------------------------
# OPTIONAL: Check intervals (in seconds)
# Minimum public  : 5  seconds
# Minimum private : 10 seconds
# ----------------------------------------------------------
PUBLIC_CHECK_SECONDS=15
PRIVATE_CHECK_SECONDS=60
